# Chord proxy — example environment.
# Copy to `.env` and fill real values. NEVER commit a real `.env`.
# Values shown are placeholders/examples only.

# ── Core ─────────────────────────────────────────────────────────────────────
# MCP tool backend (required).
MCP_BACKEND_URL=http://mcp-backend.example:3200
# JWT secret for incoming request auth (blank = auth effectively open; set it).
CHORD_JWT_SECRET=
# Upstream LLM backend for the /v1/chat/completions proxy (blank = endpoint 503).
CHORD_LLM_URL=http://llm-backend.example:11434/v1/chat/completions

# ── CSEC-02: startup-time <secret-manager> secret fetch (OPTIONAL — see src/secrets_bootstrap.rs)
#
# Before CHORD_JWT_SECRET/CHORD_API_KEY are first read, Chord attempts to fetch
# them fresh from <secret-manager> (Universal Auth, Chord's own bootstrap identity —
# NOT brokered through terminus_personal or any other fleet service) and set
# them into the process environment. Unconfigured or a failed fetch falls back
# cleanly to whatever is already in the static environment (e.g. the values
# above) — this is NEVER a hard startup failure.
#
# All four of INFISICAL_URL/INFISICAL_CLIENT_ID/INFISICAL_CLIENT_SECRET/
# CHORD_INFISICAL_PROJECT_ID must be set for the fetch to be attempted.
# INFISICAL_URL=
# INFISICAL_CLIENT_ID=
# INFISICAL_CLIENT_SECRET=
# CHORD_INFISICAL_PROJECT_ID=
# CHORD_INFISICAL_ENVIRONMENT=prod
# CHORD_INFISICAL_SECRET_PATH=/
#
# CSEC-03: crates/chord-tui reuses the same six vars above (same bootstrap
# identity + project — chord-tui is a client of Chord, not a separate service)
# to select InfisicalSecretManager over EnvSecretManager at startup. One
# additional, chord-tui-only var controls how long a fetched secret batch is
# cached (the connection manager calls resolve() once per instance per poll
# tick, so an un-cached fresh-auth-per-call would re-authenticate against
# <secret-manager> far more often than needed):
# CHORD_TUI_INFISICAL_CACHE_TTL_SECS=30

# ── S88 ISO-01: launch-env scrub & egress policy (ADVISORY — see docs/egress.md)
#
# MODEL_SOURCE_ALLOWLIST — comma/space-separated model-source hosts a model PULL
# may reach. This is the egress allow-list CONFIG SURFACE.
#
#   * UNSET or empty  → every pull is DENIED (fail closed). Chord NEVER defaults
#                       to allow-all; an unconfigured allow-list blocks pulls.
#   * The values below are PUBLIC EXAMPLES only. The real allow-list for a given
#     host comes from that host's egress audit — do not assume these are correct
#     for your deployment.
MODEL_SOURCE_ALLOWLIST=registry.ollama.ai,huggingface.co

# CHORD_OUTBOUND_PROXY — explicit Chord outbound proxy URL. When UNSET, runtime
# launches strip ALL proxy vars (HTTP_PROXY/HTTPS_PROXY/ALL_PROXY + lowercase) and
# never inherit them. When set, an allow-listed Pull launch is given this proxy;
# a Serve launch never gets one (it has no egress).
# CHORD_OUTBOUND_PROXY=http://chord-proxy.example:3128

# CHORD_RUNTIME_TELEMETRY_OFF — master toggle for the telemetry-off / offline
# opt-outs applied to runtime launches (default: true). Set to false only to debug
# a runtime that misbehaves with the opt-outs set. When on, runtime launches carry:
#   DO_NOT_TRACK=1
#   OLLAMA_NO_ANALYTICS=1  OLLAMA_NOPRUNE=1  OLLAMA_NO_UPDATE_CHECK=1
#   HF_HUB_OFFLINE=1       TRANSFORMERS_OFFLINE=1
CHORD_RUNTIME_TELEMETRY_OFF=true

# ── S88 ISO-02: per-runtime network-namespace isolation (the KERNEL guarantee) ─
#
# ISO-02 spawns each launched runtime inside its own Linux network namespace so a
# Serve runtime physically has NO route off the box (every external connect fails
# at the kernel) and a Pull runtime has only a constrained, nftables-filtered path
# to the MODEL_SOURCE_ALLOWLIST hosts. Requires CAP_NET_ADMIN + the ip/nft
# userspace. Linux-only.
#
# CHORD_NETNS_ISOLATION — isolation is DEFAULT-ON. Set to 0 ONLY to disable it for
# unprivileged dev/CI (the legacy non-isolated launch path). Any other value (or
# unset) keeps isolation on.
# CHORD_NETNS_ISOLATION=1
#
# CHORD_ALLOW_UNISOLATED — explicit operator override: when isolation is ON but the
# namespace CANNOT be created (no CAP_NET_ADMIN / tooling), Chord FAILS CLOSED and
# refuses to launch. Set EXACTLY to 1 to instead launch WITHOUT isolation (loud,
# logged at warn). Off by default — do NOT set in production.
# CHORD_ALLOW_UNISOLATED=1
#
# CHORD_IP_BIN / CHORD_NFT_BIN — the iproute2 `ip` and nftables `nft` binaries used
# to build/teardown the namespace and apply the Pull allow-list filter. Unset →
# resolved from PATH (`ip` / `nft`). Set to a blank value to disable that tool path.
# CHORD_IP_BIN=ip
# CHORD_NFT_BIN=nft

# ── SNAP observability → Postgres persistence (default-OFF) ───────────────────
# CHORD_SNAP_PERSIST — when "true"/"1"/"yes"/"on", chord's SNAP observability
# streams (request analytics, model inventory, VRAM samples, activity polls) are
# persisted to Postgres. DEFAULT OFF: when unset SNAP runs in-memory / JSONL
# exactly as before (zero behavior change) and NO DB pool is opened.
#
# When ON, SNAP REUSES the existing intake DB pool — the URL is resolved from
# INTAKE_DATABASE_URL (then DATABASE_URL), the SAME DB the serving profile and
# the model-intake harnesses already use. There is NO new secret and NO separate
# DSN here; if neither var resolves, persistence silently disables (never crashes).
# Tables (snap_request_log, snap_model_inventory, snap_activity, snap_vram_sample
# + child snap_vram_allocation) are created in-code at startup (CREATE TABLE IF
# NOT EXISTS). See docs/snap-persistence.md.
# CHORD_SNAP_PERSIST=false
#
# SNAP_VRAM_SAMPLE_SECS — row-bloat guard: minimum seconds between persisted VRAM
# samples (default 30). A sample is written at most once per this interval AND
# only when used_mb / allocation-count changed, so a fast health poll can't flood
# snap_vram_sample.
# SNAP_VRAM_SAMPLE_SECS=30

# ── Sweep-status monitor: intake-coder-sweep / intake-assistant-sweep health ──
# Built after a real 7-hour silent jam (GPU pegged 99% busy, zero new DB rows) —
# a gfx1151 GPU-MoE-wedge in Ollama's runner subprocess. This is the "is the
# fleet's model-benchmarking work healthy right now" observability surface:
# GET /v1/sweep/status and GET /v1/sweep/status/history?hours=N (no auth, same
# bar as /health and /v1/audit/summary — aggregate health, no identities/secrets).
#
# The DB URL is NOT a new secret: it reuses INTAKE_DATABASE_URL (falling back to
# DATABASE_URL) — the SAME var the serving-profile routing map and SNAP
# persistence already read. Unset ⇒ DB-derived fields report "unavailable" but
# GPU/Ollama/systemd signals are still collected (never a startup failure).
#
# CHORD_SWEEP_STATUS_LOG — JSONL log "template" path; daily-rotated files are
# derived from it (dir + stem + date + ext), e.g. the default below yields
# /var/log/chord/sweep-status-2026-07-02.jsonl, etc. See src/sweep_status/log.rs
# for the rotation-vs-single-file-trim design rationale.
# CHORD_SWEEP_STATUS_LOG=/var/log/chord/sweep-status.jsonl
#
# CHORD_SWEEP_POLL_INTERVAL_SECS — tick cadence (default 30).
# CHORD_SWEEP_POLL_INTERVAL_SECS=30
#
# CHORD_SWEEP_RETENTION_DAYS — how many days of daily JSONL files to keep;
# older files are deleted wholesale each tick (default 10).
# CHORD_SWEEP_RETENTION_DAYS=10
#
# CHORD_SWEEP_STUCK_AGE_SECS / CHORD_SWEEP_GPU_BUSY_THRESHOLD — the stuck
# heuristic's two thresholds (defaults 360s / 70%), mirroring the host-level
# watchdog that already auto-restarts ollama.service for this exact symptom.
# CHORD_SWEEP_STUCK_AGE_SECS=360
# CHORD_SWEEP_GPU_BUSY_THRESHOLD=70
#
# CHORD_SWEEP_OLLAMA_URL — local Ollama base URL polled for GET /api/ps
# (default http://localhost:11434).
# CHORD_SWEEP_OLLAMA_URL=http://localhost:11434
#
# CHORD_SWEEP_CODER_SERVICE / CHORD_SWEEP_ASSISTANT_SERVICE — the systemd unit
# names checked via `systemctl is-active` (defaults match the real <host> units).
# CHORD_SWEEP_CODER_SERVICE=intake-coder-sweep.service
# CHORD_SWEEP_ASSISTANT_SERVICE=intake-assistant-sweep.service
#
# CHORD_SWEEP_DRM_ROOT — root dir scanned for card*/device/gpu_busy_percent
# (default /sys/class/drm). Override only for testing against a fake sysfs tree.
# CHORD_SWEEP_DRM_ROOT=/sys/class/drm
