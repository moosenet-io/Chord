# Chord proxy — example environment.
# Copy to `.env` and fill real values. NEVER commit a real `.env`.
# Values shown are placeholders/examples only.

# ── Core ─────────────────────────────────────────────────────────────────────
# MCP tool backend (required).
MCP_BACKEND_URL=http://mcp-backend.example:3200
# JWT secret for incoming request auth (blank = auth effectively open; set it).
CHORD_JWT_SECRET=
# Upstream LLM backend for the /v1/chat/completions proxy (blank = endpoint 503).
CHORD_LLM_URL=http://llm-backend.example:11434/v1/chat/completions

# ── S88 ISO-01: launch-env scrub & egress policy (ADVISORY — see docs/egress.md)
#
# MODEL_SOURCE_ALLOWLIST — comma/space-separated model-source hosts a model PULL
# may reach. This is the egress allow-list CONFIG SURFACE.
#
#   * UNSET or empty  → every pull is DENIED (fail closed). Chord NEVER defaults
#                       to allow-all; an unconfigured allow-list blocks pulls.
#   * The values below are PUBLIC EXAMPLES only. The real allow-list for a given
#     host comes from that host's egress audit — do not assume these are correct
#     for your deployment.
MODEL_SOURCE_ALLOWLIST=registry.ollama.ai,huggingface.co

# CHORD_OUTBOUND_PROXY — explicit Chord outbound proxy URL. When UNSET, runtime
# launches strip ALL proxy vars (HTTP_PROXY/HTTPS_PROXY/ALL_PROXY + lowercase) and
# never inherit them. When set, an allow-listed Pull launch is given this proxy;
# a Serve launch never gets one (it has no egress).
# CHORD_OUTBOUND_PROXY=http://chord-proxy.example:3128

# CHORD_RUNTIME_TELEMETRY_OFF — master toggle for the telemetry-off / offline
# opt-outs applied to runtime launches (default: true). Set to false only to debug
# a runtime that misbehaves with the opt-outs set. When on, runtime launches carry:
#   DO_NOT_TRACK=1
#   OLLAMA_NO_ANALYTICS=1  OLLAMA_NOPRUNE=1  OLLAMA_NO_UPDATE_CHECK=1
#   HF_HUB_OFFLINE=1       TRANSFORMERS_OFFLINE=1
CHORD_RUNTIME_TELEMETRY_OFF=true
